# Backend (apps/api) — loaded via node --env-file from repo root
HALCYRA_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
HALCYRA_SUPABASE_ANON_KEY=sb_publishable_...
HALCYRA_GEMINI_API_KEY=...
# Optional: enables the "Generate narration" button on audio blocks (Google
# Cloud Text-to-Speech, REST API-key auth). Free tier is 1M chars/mo for
# standard voices, but IT REQUIRES BILLING ENABLED ON THE GCP PROJECT — use a
# project separate from your Gemini key's project, since enabling billing on
# THAT project would remove Gemini's free tier (see CLAUDE.md).
# HALCYRA_GOOGLE_TTS_API_KEY=...
# Optional: enables "🌐 Translate" on the dashboard (DeepL API Free — 500k
# chars/mo, needs its own deepl.com/pro-api account). Without it, translate
# requests fail with a clear error; nothing else in the app is affected.
# HALCYRA_DEEPL_API_KEY=...
# Optional overrides:
# HALCYRA_API_PORT=8787
# HALCYRA_WEB_ORIGIN=http://localhost:5173
# HALCYRA_AI_MODEL=gemini-2.5-flash

# Frontend vars live in apps/web/.env.local (Vite requires the VITE_ prefix):
# VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_API_URL
