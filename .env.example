# Backend (apps/api) — loaded via node --env-file from repo root
HALCYRA_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
HALCYRA_SUPABASE_ANON_KEY=sb_publishable_...
HALCYRA_GEMINI_API_KEY=...
# Optional overrides:
# HALCYRA_API_PORT=8787
# HALCYRA_WEB_ORIGIN=http://localhost:5173
# HALCYRA_AI_MODEL=gemini-2.5-flash

# Frontend vars live in apps/web/.env.local (Vite requires the VITE_ prefix):
# VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_API_URL
